// https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client"
  output          = "./generated"
  previewFeatures = ["typedSql"]
}

datasource db {
  provider = "postgresql"
}

model Day {
  date            DateTime  @id @db.Date
  user_day_loaded Boolean   @default(false)
  UserDay         UserDay[]
}

model UserDay {
  id                         Int      @id @default(autoincrement())
  user_id                    String
  date                       DateTime @db.Date
  is_active                  Boolean
  is_desktop                 Boolean
  is_ios                     Boolean
  is_android                 Boolean
  messages_posted            Int
  messages_posted_in_channel Int
  reactions_added            Int
  day                        Day      @relation(fields: [date], references: [date])
  user                       User     @relation(fields: [user_id], references: [user_id])

  @@index([user_id])
}

model User {
  user_id         String    @id
  display_name    String?
  real_name       String?
  profile_picture String?
  last_updated    DateTime  @default(dbgenerated("'1969-12-31 16:00:00-08'::timestamp with time zone")) @db.Timestamptz(6)
  UserDay         UserDay[]
}
